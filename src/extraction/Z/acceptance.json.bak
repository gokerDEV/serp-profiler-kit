{
    "filters": [
        {
            "column": "http_status",
            "op": "eq",
            "value": 200,
            "description": "Keep only records with HTTP 200"
        },
        {
            "column": "word_count",
            "op": "min",
            "value": 20,
            "description": "Drop records with less than 20 words (low content)"
        },
        {
            "column": "sim_title",
            "op": "notnull",
            "value": null,
            "description": "Drop if sim_title is missing"
        },
        {
            "column": "sim_description",
            "op": "notnull",
            "value": null,
            "description": "Drop if sim_description is missing"
        },
        {
            "column": "sim_h1",

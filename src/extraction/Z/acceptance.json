            "description": "Drop if sim_content is missing"
        },
        {
            "column": "flesch_reading_ease",
            "op": "notnull",
            "description": "Drop if flesch_reading_ease is missing"
        },
        {
            "column": "flesch_kincaid_grade",
            "op": "notnull",
            "description": "Drop if flesch_kincaid_grade is missing"
        },
        {
            "column": "lcp_ms",
